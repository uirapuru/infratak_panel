# Copy to .env.deploy and fill with production values

# --- Database ---
MARIADB_DATABASE=app
MARIADB_USER=app
MARIADB_PASSWORD=change-me
MARIADB_ROOT_PASSWORD=change-root-password

# --- RabbitMQ ---
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=change-rabbit-password

# --- App / Mail ---
APP_SECRET=change-app-secret
# Production must use a real SMTP provider; mailcatcher exists only in local/dev compose override.
MAILER_DSN=smtp://USERNAME:PASSWORD@smtp.example.com:587?encryption=tls&auth_mode=login
MAILER_FROM=no-reply@infratak.com
APP_TIMEZONE=Europe/Warsaw
TZ=Europe/Warsaw

# --- Admin basic auth ---
ADMIN_BASIC_AUTH_USER=admin
ADMIN_BASIC_AUTH_PASSWORD=change-admin-password

# --- App domain ---
APP_BASE_DOMAIN=infratak.com
APP_CERTBOT_EMAIL=admin@infratak.com

# --- Symfony internals ---
DATABASE_URL=mysql://app:MARIADB_PASSWORD@mariadb:3306/app?serverVersion=11.4.2-MariaDB&charset=utf8mb4
MESSENGER_PROVISIONING_TRANSPORT_DSN=amqp://guest:RABBITMQ_DEFAULT_PASS@rabbitmq:5672/%2f/messages
MESSENGER_PROJECTION_TRANSPORT_DSN=amqp://guest:RABBITMQ_DEFAULT_PASS@rabbitmq:5672/%2f/messages

# --- AWS ---
AWS_PROFILE=default
AWS_REGION=eu-central-1
AWS_SDK_LOAD_CONFIG=1
AWS_EC2_METADATA_DISABLED=true
AWS_ROUTE53_HOSTED_ZONE_ID=Z0843124BD4D2BF9GZ0S
AWS_EC2_AMI_ID=ami-0112fb594a28a4b98
AWS_EC2_INSTANCE_TYPE=t3.medium
AWS_EC2_SECURITY_GROUP_ID=sg-07647c9b6abf742d0
AWS_EC2_SUBNET_ID=subnet-0b9d23c01f18c5129
AWS_INSTANCE_PROFILE_NAME=infratak-ec2-profile
