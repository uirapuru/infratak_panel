<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        <link rel="preconnect" href="https://cdn.jsdelivr.net">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
        <style>
            :root {
                --bg: #0f172a;
                --bg-soft: #111b33;
                --card: #17233e;
                --text: #dce7ff;
                --muted: #93a4c9;
                --accent: #22d3ee;
                --accent-strong: #06b6d4;
                --border: rgba(147, 164, 201, 0.22);
            }

            html,
            body {
                background: radial-gradient(circle at 10% 0%, #18294d 0%, var(--bg) 52%);
                color: var(--text);
            }

            body {
                min-height: 100vh;
                line-height: 1.55;
            }

            .text-muted-custom {
                color: var(--muted);
            }

            .hero {
                padding: 4.5rem 0 2.5rem;
            }

            .section-pad {
                padding: 2.5rem 0;
            }

            .section-title {
                font-weight: 700;
                letter-spacing: 0.01em;
                margin-bottom: 1rem;
            }

            .surface-card {
                background: linear-gradient(180deg, rgba(34, 211, 238, 0.06), rgba(15, 23, 42, 0.12)), var(--card);
                border: 1px solid var(--border);
                border-radius: 0.9rem;
                height: 100%;
            }

            .badge-soft {
                background: rgba(34, 211, 238, 0.16);
                border: 1px solid rgba(34, 211, 238, 0.35);
                color: #baf7ff;
                border-radius: 999px;
                font-weight: 600;
            }

            .btn-accent {
                background-color: var(--accent);
                border-color: var(--accent);
                color: #03252d;
                font-weight: 700;
            }

            .btn-accent:hover,
            .btn-accent:focus {
                background-color: var(--accent-strong);
                border-color: var(--accent-strong);
                color: #021a22;
            }

            .list-clean {
                margin: 0;
                padding-left: 1.05rem;
            }

            .list-clean li {
                margin-bottom: 0.45rem;
            }
        </style>
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body>
        {% block body %}{% endblock %}
    </body>
</html>
