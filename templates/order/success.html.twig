{% extends 'base.html.twig' %}

{% block title %}Serwer zamówiony — Infratak{% endblock %}

{% block body %}
<div class="container py-4" style="max-width: 640px;">

    <header class="text-center mb-5 pt-3">
        <div style="font-size: 3rem; margin-bottom: 1rem;">✓</div>
        <h1 class="h2 fw-bold mb-2">Serwer jest w drodze!</h1>
        <p class="text-muted-custom">Provisioning uruchomiony. Serwer będzie gotowy za kilka minut.</p>
    </header>

    <div class="surface-card p-4 mb-4">
        <p class="text-uppercase small fw-semibold mb-3" style="color: var(--accent); letter-spacing: .06em;">Adres Twojego serwera</p>

        <div class="mb-3">
            <div class="small text-muted-custom mb-1">Serwer OpenTAK (OTS)</div>
            <div class="d-flex align-items-center gap-2">
                <code class="fs-5 fw-semibold" style="color: var(--text);">{{ domain }}</code>
                <button type="button" class="btn btn-sm btn-outline-secondary js-copy" data-copy="{{ domain }}" aria-label="Kopiuj">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M4 1.5H3a2 2 0 0 0-2 2V14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V3.5a2 2 0 0 0-2-2h-1v1h1a1 1 0 0 1 1 1V14a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V3.5a1 1 0 0 1 1-1h1v-1z"/>
                        <path d="M9.5 1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-3a.5.5 0 0 1-.5-.5v-1a.5.5 0 0 1 .5-.5h3zm-3-1A1.5 1.5 0 0 0 5 1.5v1A1.5 1.5 0 0 0 6.5 4h3A1.5 1.5 0 0 0 11 2.5v-1A1.5 1.5 0 0 0 9.5 0h-3z"/>
                    </svg>
                </button>
            </div>
        </div>

        <div>
            <div class="small text-muted-custom mb-1">Boarding Portal</div>
            <div class="d-flex align-items-center gap-2">
                <code style="color: var(--text);">{{ portalDomain }}</code>
                <button type="button" class="btn btn-sm btn-outline-secondary js-copy" data-copy="{{ portalDomain }}" aria-label="Kopiuj">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M4 1.5H3a2 2 0 0 0-2 2V14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V3.5a2 2 0 0 0-2-2h-1v1h1a1 1 0 0 1 1 1V14a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V3.5a1 1 0 0 1 1-1h1v-1z"/>
                        <path d="M9.5 1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-3a.5.5 0 0 1-.5-.5v-1a.5.5 0 0 1 .5-.5h3zm-3-1A1.5 1.5 0 0 0 5 1.5v1A1.5 1.5 0 0 0 6.5 4h3A1.5 1.5 0 0 0 11 2.5v-1A1.5 1.5 0 0 0 9.5 0h-3z"/>
                    </svg>
                </button>
            </div>
        </div>
    </div>

    <div class="surface-card p-4 mb-4">
        <p class="text-uppercase small fw-semibold mb-3" style="color: var(--accent); letter-spacing: .06em;">Dane logowania do panelu</p>
        <p class="small text-muted-custom mb-3">Zapisz je — hasło nie będzie wyświetlone ponownie.</p>

        <div class="mb-3">
            <div class="small text-muted-custom mb-1">Adres panelu</div>
            <code style="color: var(--text);">infratak.com/login</code>
        </div>

        <div class="mb-3">
            <div class="small text-muted-custom mb-1">Login (e-mail)</div>
            <div class="d-flex align-items-center gap-2">
                <code style="color: var(--text);">{{ email }}</code>
                <button type="button" class="btn btn-sm btn-outline-secondary js-copy" data-copy="{{ email }}" aria-label="Kopiuj">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M4 1.5H3a2 2 0 0 0-2 2V14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V3.5a2 2 0 0 0-2-2h-1v1h1a1 1 0 0 1 1 1V14a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V3.5a1 1 0 0 1 1-1h1v-1z"/>
                        <path d="M9.5 1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-3a.5.5 0 0 1-.5-.5v-1a.5.5 0 0 1 .5-.5h3zm-3-1A1.5 1.5 0 0 0 5 1.5v1A1.5 1.5 0 0 0 6.5 4h3A1.5 1.5 0 0 0 11 2.5v-1A1.5 1.5 0 0 0 9.5 0h-3z"/>
                    </svg>
                </button>
            </div>
        </div>

        <div>
            <div class="small text-muted-custom mb-1">Hasło</div>
            <div class="d-flex align-items-center gap-2">
                <code id="pwd-value" style="color: var(--text);">{{ password }}</code>
                <button type="button" class="btn btn-sm btn-outline-secondary js-copy" data-copy="{{ password }}" aria-label="Kopiuj">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M4 1.5H3a2 2 0 0 0-2 2V14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V3.5a2 2 0 0 0-2-2h-1v1h1a1 1 0 0 1 1 1V14a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V3.5a1 1 0 0 1 1-1h1v-1z"/>
                        <path d="M9.5 1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-3a.5.5 0 0 1-.5-.5v-1a.5.5 0 0 1 .5-.5h3zm-3-1A1.5 1.5 0 0 0 5 1.5v1A1.5 1.5 0 0 0 6.5 4h3A1.5 1.5 0 0 0 11 2.5v-1A1.5 1.5 0 0 0 9.5 0h-3z"/>
                    </svg>
                </button>
            </div>
        </div>
    </div>

    <div class="surface-card p-4 mb-4" style="border-color: rgba(34, 211, 238, 0.3);">
        <p class="fw-semibold mb-1">Czas działania serwera</p>
        <p class="text-muted-custom mb-0" style="font-size: 0.92rem;">
            Twój kod promocyjny przyznał <strong>{{ durationDays }} {{ durationDays == 1 ? 'dzień' : (durationDays < 5 ? 'dni' : 'dni') }}</strong> działania serwera.
            Po upływie tego czasu serwer zostanie zatrzymany.
        </p>
    </div>

    <div class="surface-card p-4 mb-4" style="border-color: rgba(34, 211, 238, 0.3);">
        <p class="fw-semibold mb-1">Hasło administratora OpenTAK (OTS)</p>
        <p class="text-muted-custom mb-0" style="font-size: 0.92rem;">
            Hasło admina OTS zostanie wygenerowane automatycznie po zakończeniu provisioningu serwera.
            Znajdziesz je w panelu Infratak w widoku szczegółów serwera — pojawi się gdy serwer osiągnie status <strong>Ready</strong>.
        </p>
    </div>

    <div class="d-flex gap-2">
        <a href="{{ path('app_login') }}" class="btn btn-accent px-4">Zaloguj się do panelu</a>
        <a href="{{ path('home') }}" class="btn btn-outline-secondary">Strona główna</a>
    </div>
</div>

<script>
document.querySelectorAll('.js-copy').forEach(function (btn) {
    btn.addEventListener('click', function () {
        navigator.clipboard.writeText(this.dataset.copy).then(function () {
            btn.textContent = '✓';
            setTimeout(function () {
                btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path d="M4 1.5H3a2 2 0 0 0-2 2V14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V3.5a2 2 0 0 0-2-2h-1v1h1a1 1 0 0 1 1 1V14a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V3.5a1 1 0 0 1 1-1h1v-1z"/><path d="M9.5 1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-3a.5.5 0 0 1-.5-.5v-1a.5.5 0 0 1 .5-.5h3zm-3-1A1.5 1.5 0 0 0 5 1.5v1A1.5 1.5 0 0 0 6.5 4h3A1.5 1.5 0 0 0 11 2.5v-1A1.5 1.5 0 0 0 9.5 0h-3z"/></svg>';
            }, 1500);
        });
    }.bind(btn));
});
</script>
{% endblock %}
