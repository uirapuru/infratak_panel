{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}Change OpenTAK admin password{% endblock %}

{% block page_actions %}
    <a class="btn btn-secondary" href="{{ detailUrl }}">Back to server</a>
{% endblock %}

{% block main %}
    <form method="post" class="content-panel" style="max-width: 720px;">
        <input type="hidden" name="_token" value="{{ csrf_token(csrfTokenId) }}">

        <div class="content-panel-body">
            <dl class="row mb-4">
                <dt class="col-sm-3">Server</dt>
                <dd class="col-sm-9">{{ server.name }}</dd>
                <dt class="col-sm-3">Domain</dt>
                <dd class="col-sm-9">{{ server.domain }}</dd>
            </dl>

            <div class="mb-3">
                <label class="form-label" for="newPassword">New admin password</label>
                <input
                    class="form-control"
                    id="newPassword"
                    name="newPassword"
                    type="password"
                    minlength="16"
                    autocomplete="new-password"
                    required
                    autofocus
                >
                <div class="form-text">Minimum 16 characters. The value is queued for the provisioning worker and saved after OTS confirms the change.</div>
            </div>

            <div class="mb-4">
                <label class="form-label" for="confirmPassword">Confirm new admin password</label>
                <input
                    class="form-control"
                    id="confirmPassword"
                    name="confirmPassword"
                    type="password"
                    minlength="16"
                    autocomplete="new-password"
                    required
                >
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Queue password change</button>
                <a class="btn btn-secondary" href="{{ detailUrl }}">Cancel</a>
            </div>
        </div>
    </form>
{% endblock %}
