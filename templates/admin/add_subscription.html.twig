{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}Add server subscription{% endblock %}

{% block page_actions %}
    <a class="btn btn-secondary" href="{{ detailUrl }}">Back to server</a>
{% endblock %}

{% block main %}
    <form method="post" class="content-panel" style="max-width: 720px;">
        <input type="hidden" name="_token" value="{{ csrf_token(csrfTokenId) }}">

        <div class="content-panel-body">
            <dl class="row mb-4">
                <dt class="col-sm-3">Server</dt>
                <dd class="col-sm-9">{{ server.name }}</dd>
                <dt class="col-sm-3">Owner</dt>
                <dd class="col-sm-9">{{ owner.email }}</dd>
                <dt class="col-sm-3">Current paid until</dt>
                <dd class="col-sm-9">
                    {% if server.subscriptionPaidUntil %}
                        {{ server.subscriptionPaidUntil|date('Y-m-d H:i', 'Europe/Warsaw') }}
                    {% else %}
                        <span class="text-muted">No active subscription</span>
                    {% endif %}
                </dd>
                <dt class="col-sm-3">Price</dt>
                <dd class="col-sm-9">{{ pricePerDayPln }} PLN / day</dd>
            </dl>

            <div class="mb-4">
                <label class="form-label" for="days">Days</label>
                <input
                    class="form-control"
                    id="days"
                    name="days"
                    type="number"
                    min="1"
                    max="366"
                    step="1"
                    value="1"
                    required
                    autofocus
                >
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Add subscription</button>
                <a class="btn btn-secondary" href="{{ detailUrl }}">Cancel</a>
            </div>
        </div>
    </form>
{% endblock %}
