<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Infratak Admin — logowanie</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #0f172a;
            font-family: system-ui, -apple-system, sans-serif;
            color: #dce7ff;
        }

        .card {
            width: 100%;
            max-width: 380px;
            background: #17233e;
            border: 1px solid rgba(147,164,201,.22);
            border-radius: 12px;
            padding: 40px 36px;
        }

        .logo {
            text-align: center;
            margin-bottom: 28px;
            font-size: 20px;
            font-weight: 700;
            letter-spacing: .5px;
            color: #22d3ee;
        }

        .logo span { color: #dce7ff; }

        label {
            display: block;
            font-size: 13px;
            color: #93a4c9;
            margin-bottom: 6px;
        }

        input[type="email"],
        input[type="password"] {
            width: 100%;
            background: #0f172a;
            border: 1px solid rgba(147,164,201,.3);
            border-radius: 8px;
            padding: 10px 14px;
            color: #dce7ff;
            font-size: 15px;
            outline: none;
            transition: border-color .15s;
        }

        input:focus { border-color: #22d3ee; }

        .field { margin-bottom: 18px; }

        .remember {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 13px;
            color: #93a4c9;
            margin-bottom: 24px;
        }

        button[type="submit"] {
            width: 100%;
            background: #22d3ee;
            color: #0f172a;
            border: none;
            border-radius: 8px;
            padding: 11px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: background .15s;
        }

        button[type="submit"]:hover { background: #06b6d4; }

        .alert {
            background: rgba(239,68,68,.15);
            border: 1px solid rgba(239,68,68,.4);
            border-radius: 8px;
            padding: 10px 14px;
            font-size: 13px;
            color: #fca5a5;
            margin-bottom: 18px;
        }
    </style>
</head>
<body>
<div class="card">
    <div class="logo">Infra<span>tak</span> Admin</div>

    {% if error %}
        <div class="alert">{{ error.messageKey | trans(error.messageData, 'security') }}</div>
    {% endif %}

    <form method="post">
        <div class="field">
            <label for="email">E-mail</label>
            <input type="email" id="email" name="_username"
                   value="{{ last_username }}" autocomplete="email" autofocus required>
        </div>

        <div class="field">
            <label for="password">Hasło</label>
            <input type="password" id="password" name="_password"
                   autocomplete="current-password" required>
        </div>

        <div class="remember">
            <input type="checkbox" id="remember" name="_remember_me">
            <label for="remember" style="margin:0">Zapamiętaj mnie</label>
        </div>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <button type="submit">Zaloguj się</button>
    </form>
</div>
</body>
</html>
