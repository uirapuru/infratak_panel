{%- set colorMap = {
    'none': 'secondary',
    'creating': 'info',
    'diagnosing': 'primary',
    'provisioning': 'info',
    'cert_pending': 'warning',
    'ready': 'success',
    'failed': 'danger',
    'deleted': 'secondary',
    'stopped': 'warning',
    'ROLE_ADMIN': 'warning',
    'ROLE_SUPER_ADMIN': 'danger',
    'ROLE_USER': 'secondary'
} -%}

{%- set rawValue = field.value|default(null) -%}
{%- set rawValue = rawValue.value|default(rawValue) -%}

{%- if rawValue is iterable -%}
    {%- for item in rawValue -%}
        {%- set badgeKey = item.value|default(item) -%}
        {%- if badgeKey != 'none' -%}
            {%- set color = colorMap[badgeKey]|default('secondary') -%}
            <span class="badge bg-{{ color }}">{{ badgeKey|trans }}</span>
        {%- endif -%}
    {%- endfor -%}
{%- else -%}
    {%- set badgeKey = rawValue|default('') -%}
    {%- if badgeKey == 'none' -%}
        <span></span>
    {%- else -%}
        {%- set color = colorMap[badgeKey]|default('secondary') -%}
        <span class="badge bg-{{ color }}">{{ field.formattedValue|default(field.value)|trans|raw }}</span>
    {%- endif -%}
{%- endif -%}
